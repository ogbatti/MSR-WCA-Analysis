# Example Streamlit secrets for MSR WCA staging (Phase 2)
# Copy into Streamlit Cloud → App settings → Secrets
# Local: copy to .streamlit/secrets.toml (gitignored)

ACTIVITYINFO_TOKEN = "your-activityinfo-token"
MSR_CHANNEL = "staging"

# Auth modes: open | password | users | oidc
AUTH_MODE = "password"
APP_PASSWORD = "change-me-staging"

# Optional per-user accounts (AUTH_MODE = "users")
# [app_users.alice]
# password = "..."
# name = "Alice DIMA"
# email = "alice@example.org"
# role = "admin"          # reader | country | admin
# countries = ["CMR", "TCD"]  # only for role=country

# Assistant (Phase 3) — figures always from tools; LLM only rephrases if enabled
# ASSISTANT_LLM = "off"
# OPENAI_API_KEY = ""
# OPENAI_BASE_URL = "https://api.openai.com/v1"
# OPENAI_MODEL = "gpt-4o-mini"

# Optional OIDC (AUTH_MODE = "oidc") — Azure AD / Microsoft example
# [auth]
# redirect_uri = "https://YOUR-STAGING-APP.streamlit.app/oauth2callback"
# cookie_secret = "long-random-string"
# client_id = "..."
# client_secret = "..."
# server_metadata_url = "https://login.microsoftonline.com/YOUR_TENANT/v2.0/.well-known/openid-configuration"
